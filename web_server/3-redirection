#!/usr/bin/env bash
# Configures an Nginx server so that /redirect_me redirects to another page
# The redirection is a "301 Moved Permanently"
set -e

# Update and install nginx
apt-get update -y
apt-get install -y nginx

# Remove default html files
rm -rf /var/www/html/*

# Create a simple homepage (optional)
echo -n "Holberton School" > /var/www/html/index.html

# Configure Nginx for /redirect_me with 301 redirect
cat <<EOF > /etc/nginx/sites-available/default
server {
    listen 80 default_server;
    listen [::]:80 default_server;

    root /var/www/html;
    index index.html index.htm;

    server_name _;

    location / {
        try_files \$uri \$uri/ =404;
    }

    location /redirect_me {
        return 301 https://www.youtube.com/watch?v=QH2-TGUlwu4;
    }
}
EOF

# Restart nginx (without systemctl)
service nginx restart