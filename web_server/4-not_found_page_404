#!/usr/bin/env bash
# Configures Nginx with a custom 404 page containing "Ceci n'est pas une page"

apt-get update -y
apt-get install -y nginx

# Create custom homepage
echo "Holberton School" | tee /var/www/html/index.html > /dev/null

# Create custom 404 page
echo "Ceci n'est pas une page" | tee /var/www/html/404.html > /dev/null

# Remove existing default configs
rm -f /etc/nginx/sites-enabled/default
rm -f /etc/nginx/sites-available/default

# Write clean config
tee /etc/nginx/sites-available/default > /dev/null <<'NGINX'
server {
    listen 80 default_server;
    listen [::]:80 default_server;

    root /var/www/html;
    index index.html index.htm;

    server_name _;

    error_page 404 /404.html;

    location /redirect_me {
        return 301 https://www.youtube.com/;
    }

    location / {
        try_files $uri $uri/ =404;
    }
}
NGINX

# Create symlink
ln -s /etc/nginx/sites-available/default /etc/nginx/sites-enabled/default

nginx -t && service nginx restart
