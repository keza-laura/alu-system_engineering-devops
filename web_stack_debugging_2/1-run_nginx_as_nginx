#!/usr/bin/env bash
# Configure Nginx to run as nginx user and listen on port 8080

# Ensure nginx user exists
id nginx || useradd -r nginx

# Update Nginx config to run as nginx user
sed -i 's/^user .*/user nginx;/' /etc/nginx/nginx.conf

# Change default site to listen on port 8080
sed -i 's/listen 80 default_server;/listen 8080 default_server;/' /etc/nginx/sites-available/default
sed -i 's/listen \[::\]:80 default_server;/listen [::]:8080 default_server;/' /etc/nginx/sites-available/default

# Ensure proper permissions for web files
chown -R nginx:nginx /var/www/html

# Restart Nginx
service nginx restart
