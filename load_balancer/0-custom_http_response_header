#!/usr/bin/env bash
# Configures a new Ubuntu machine to have Nginx with a custom HTTP response header
# X-Served-By: <hostname of the server>

# Update and install Nginx
apt-get update -y
apt-get install -y nginx

# Get the hostname of the server
HOSTNAME=$(hostname)

# Write a clean Nginx default site config with the custom header
cat > /etc/nginx/sites-available/default << NGINXCONF
server {
    listen 80 default_server;
    listen [::]:80 default_server;

    root /var/www/html;
    index index.html index.htm index.nginx-debian.html;

    server_name _;

    add_header X-Served-By $HOSTNAME;

    location / {
        try_files \$uri \$uri/ =404;
    }
}
NGINXCONF

# Test config and restart Nginx
nginx -t && systemctl restart nginx

# shellcheck disable=SC2154
